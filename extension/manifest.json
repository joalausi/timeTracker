{
  "manifest_version": 3,
  "name": "Time Tracker",
  "version": "0.0.1",
  "permissions": [
    "nativeMessaging",
    "tabs",
    "windows",
    "idle",
    "storage"
  ],
  "background": {
    "service_worker": "sw.js"
  },
  "action": {
    "default_title": "Time Tracker",
    "default_popup": "popup.html"
  }
}
